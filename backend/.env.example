GROQ_API_KEY=gsk_your_secret_key_here
PORT=3001

# Comma-separated browser origins allowed to call this API (default: localhost:4200 for ng serve).
# Production: explicit https:// origins — recruita.runtime production mode refuses CORS_ORIGIN=* at startup.
# CORS_ORIGIN=https://app.example.com

# Max POST /api/match requests per IP per window (default 100; see application.yml).
# MATCH_RATE_LIMIT_MAX=200

# Set to 1 when running behind a reverse proxy so rate limits use X-Forwarded-For.
# TRUST_PROXY=1

# Force HSTS from Spring when TLS terminates elsewhere (HTTPS end-to-end to client).
# ENABLE_HSTS=1

# Optional: NVD API key speeds OWASP Dependency-Check NVD sync (https://nvd.nist.gov/developers/request-an-api-key).
# NVD_API_KEY=your-nvd-api-key
