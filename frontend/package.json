{
  "name": "@recruita/frontend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "format": "prettier --write \"**/*.{ts,html,scss,css,json,yml,yaml}\" --ignore-path ../.prettierignore",
    "format:check": "prettier --check \"**/*.{ts,html,scss,css,json,yml,yaml}\" --ignore-path ../.prettierignore",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "quality": "npm run format:check && npm run lint",
    "quality:fix": "npm run format && npm run lint:fix",
    "doctor": "angular-doctor --yes --fast --no-lint .",
    "doctor:full": "angular-doctor --yes --no-lint .",
    "doctor:lint": "angular-doctor --yes --fast --exit-code .",
    "security:audit": "ngx-security-audit scan -t high --no-color .",
    "letify": "letify analyze \"src/**/*.html\" -r list --open false",
    "test": "ng test",
    "test:ci": "ng test --no-watch --code-coverage --browsers=ChromeHeadlessNoSandbox",
    "test:coverage": "ng test --code-coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install chromium",
    "clean": "rimraf dist/"
  },
  "dependencies": {
    "@angular/animations": "^20.3.18",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/forms": "^20.3.18",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.18",
    "@angular/platform-browser-dynamic": "^20.3.18",
    "@angular/router": "^20.3.18",
    "@angular/service-worker": "^20.3.18",
    "@fontsource/manrope": "^5.2.8",
    "@mdi/font": "^7.4.47",
    "@ngrx/data": "^20.1.0",
    "@ngrx/effects": "^20.0.0",
    "@ngrx/entity": "^20.0.0",
    "@ngrx/operators": "^20.1.0",
    "@ngrx/store": "^20.0.0",
    "@ngrx/store-devtools": "^20.0.0",
    "@ngx-translate/core": "^15.0.0",
    "@ngx-translate/http-loader": "^8.0.0",
    "rxjs": "^7.8.1",
    "sass": "^1.70.0",
    "tslib": "^2.6.0",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.18",
    "@angular-eslint/builder": "^20.7.0",
    "@angular-eslint/eslint-plugin": "^20.7.0",
    "@angular-eslint/eslint-plugin-template": "^20.7.0",
    "@angular-eslint/schematics": "^20.7.0",
    "@angular-eslint/template-parser": "^20.7.0",
    "@angular/cli": "^20.3.18",
    "@angular/compiler-cli": "^20.3.18",
    "@angular/localize": "^20.3.18",
    "@eslint/config-array": "^0.19.1",
    "@eslint/object-schema": "^2.1.5",
    "@jsverse/letify": "^1.0.0",
    "@microsoft/eslint-plugin-sdl": "^0.2.2",
    "@playwright/test": "^1.59.1",
    "@types/file-saver": "^2.0.7",
    "@types/jasmine": "^4.6.0",
    "@types/node": "^20.17.10",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@typescript-eslint/utils": "^8.18.0",
    "angular-doctor": "^1.3.0",
    "autoprefixer": "^10.4.27",
    "beasties": "^0.2.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-rxjs": "^5.0.3",
    "eslint-plugin-rxjs-angular": "^2.0.1",
    "eslint-plugin-unicorn": "^56.0.1",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "glob": "^11.0.0",
    "jasmine-core": "^4.6.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "ngx-security-audit": "^2.0.1",
    "pdf-lib": "^1.17.1",
    "postcss": "^8.5.9",
    "prettier": "^3.0.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.19",
    "typescript": "5.9.3",
    "webpack": "^5.96.1"
  },
  "optionalDependencies": {
    "@oxc-resolver/binding-darwin-arm64": "11.19.1",
    "@oxc-resolver/binding-darwin-x64": "11.19.1",
    "@oxc-resolver/binding-linux-x64-gnu": "11.19.1"
  }
}
