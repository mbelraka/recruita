{
  "name": "recruita",
  "version": "0.0.0",
  "private": true,
  "description": "Recruita monorepo — Angular frontend + Spring backend",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "sh scripts/run-dev.sh",
    "start": "npm run start -w @recruita/frontend",
    "start:all": "npm run dev",
    "start:backend": "sh scripts/start-backend.sh",
    "start:backend:prod": "sh scripts/start-backend-prod.sh",
    "infra:up": "sh scripts/infra-up.sh",
    "infra:down": "sh scripts/infra-down.sh",
    "seed:applicants": "sh scripts/seed-applicants.sh",
    "build": "npm run build -w @recruita/frontend",
    "build:prod": "npm run build:prod -w @recruita/frontend",
    "watch": "npm run watch -w @recruita/frontend",
    "test": "npm run test -w @recruita/frontend",
    "test:ci": "npm run test:ci -w @recruita/frontend",
    "test:coverage": "npm run test:coverage -w @recruita/frontend",
    "e2e": "npm run e2e -w @recruita/frontend",
    "e2e:ui": "npm run e2e:ui -w @recruita/frontend",
    "e2e:headed": "npm run e2e:headed -w @recruita/frontend",
    "e2e:install": "npm run e2e:install -w @recruita/frontend",
    "clean": "npm run clean -w @recruita/frontend",
    "format": "npm run format -w @recruita/frontend",
    "format:check": "npm run format:check -w @recruita/frontend && npm run format:check:backend",
    "format:backend": "sh scripts/run-mvn.sh spotless:apply -q",
    "format:check:backend": "sh scripts/run-mvn.sh spotless:check -q",
    "lint": "npm run lint -w @recruita/frontend && npm run lint:backend",
    "lint:fix": "npm run lint:fix -w @recruita/frontend",
    "lint:backend": "sh scripts/run-mvn.sh checkstyle:check -q",
    "quality": "npm run quality -w @recruita/frontend && npm run quality:backend",
    "quality:fix": "npm run quality:fix -w @recruita/frontend && npm run quality:fix:backend",
    "quality:backend": "npm run format:check:backend && npm run lint:backend",
    "quality:fix:backend": "npm run format:backend",
    "doctor": "npm run doctor -w @recruita/frontend",
    "doctor:full": "npm run doctor:full -w @recruita/frontend",
    "doctor:lint": "npm run doctor:lint -w @recruita/frontend",
    "security:audit": "npm run security:audit -w @recruita/frontend",
    "security:audit:backend": "sh scripts/run-security-audit.sh",
    "letify": "npm run letify -w @recruita/frontend",
    "test:backend": "sh scripts/run-mvn.sh test -q",
    "verify:backend": "sh scripts/run-mvn.sh verify -q",
    "export:openapi": "sh scripts/export-openapi-spec.sh",
    "codegen:api": "sh scripts/codegen-openapi-frontend.sh",
    "codegen:api:check": "sh scripts/codegen-openapi-check.sh",
    "validate:openapi:contract": "sh scripts/validate-openapi-spec.sh",
    "validate:openapi:drift": "sh scripts/validate-openapi-drift.sh",
    "validate:openapi:backend": "npm run validate:openapi:drift",
    "precommit:frontend": "npm run validate:ci:frontend",
    "precommit:backend": "npm run validate:ci:backend",
    "validate:ci:frontend": "npm run codegen:api:check && npm run quality -w @recruita/frontend && npm run test:ci -w @recruita/frontend && npm run doctor:full -w @recruita/frontend && npm run security:audit -w @recruita/frontend && npm run letify -w @recruita/frontend && npm run build:prod -w @recruita/frontend",
    "validate:ci:backend": "npm run quality:backend && npm run verify:backend && npm run validate:openapi:contract",
    "validate:ci": "npm run validate:ci:frontend && npm run validate:ci:backend",
    "validate": "npm run validate:ci",
    "lockfile:check": "npm install --package-lock-only --ignore-scripts --loglevel=error && git diff --exit-code package-lock.json",
    "postinstall": "patch-package",
    "prepare": "husky"
  },
  "packageManager": "npm@10.9.2",
  "overrides": {
    "@babel/helper-compilation-targets": {
      "lru-cache": "5.1.1"
    }
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "ng-openapi-gen": "^1.0.5",
    "openapi-diff": "^0.24.1",
    "@stoplight/prism-cli": "^5.15.11",
    "yaml": "^2.8.1",
    "patch-package": "^8.0.1",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.9.2"
  },
  "lint-staged": {
    "frontend/src/**/!(*generated*)/*.{ts,html}": [
      "bash -c 'cd frontend && eslint --fix --max-warnings=0 \"$@\"' _",
      "prettier --write"
    ],
    "frontend/src/app/generated/**/*.{ts,html}": [
      "prettier --write"
    ],
    "frontend/e2e/**/*.ts": [
      "bash -c 'cd frontend && eslint --fix --max-warnings=0 \"$@\"' _",
      "prettier --write"
    ],
    "frontend/e2e/**/*.html": [
      "prettier --write"
    ],
    "frontend/playwright.config.ts": [
      "prettier --write"
    ],
    "frontend/**/*.{scss,css,json,yml,yaml}": [
      "prettier --write"
    ],
    "backend/**/*.java": [
      "bash -c 'sh scripts/run-mvn.sh spotless:apply -q' --"
    ],
    "backend/**/*.{yml,yaml}": [
      "prettier --write"
    ],
    "*.{scss,css,json,yml,yaml}": [
      "prettier --write"
    ]
  }
}
