# Optional: requires direnv (https://direnv.net). Unsets Cursor sandbox npm env in any terminal.
unset NPM_CONFIG_DEVDIR npm_config_devdir

if [ -z "${JAVA_HOME:-}" ] && [ -f backend/.java-version ] && [ -x /usr/libexec/java_home ]; then
  JAVA_VERSION="$(tr -d '[:space:]' < backend/.java-version)"
  JAVA_HOME="$(/usr/libexec/java_home -v "$JAVA_VERSION" 2>/dev/null || true)"
  [ -n "$JAVA_HOME" ] && export JAVA_HOME
fi
